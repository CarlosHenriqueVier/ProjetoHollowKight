{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar e Rodar Raylib",
            "command": "g++",
            "args": [
                "./Projeto/main.cpp",
                "./Projeto/Estruturas/estruturas.cpp",
                "./Projeto/Funcoes/funcoes.cpp",
                "-o",
                "./Projeto/programa.exe",
                "-I${workspaceFolder}/Projeto/raylib/include",
                "-L${workspaceFolder}/Projeto/raylib/lib",
                "${workspaceFolder}/Projeto/raylib/lib/raylib.dll",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm",
                ";",
                "Copy-Item",
                "-Path",
                ".\\Projeto\\raylib\\lib\\raylib.dll",
                "-Destination",
                ".\\Projeto\\",
                "-Force",
                ";",
                ".\\Projeto\\programa.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}