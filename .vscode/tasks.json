{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar e Rodar Raylib",
            "command": "g++",
            "args": [
                "${workspaceFolder}/Projeto/main.cpp",
                "${workspaceFolder}/Projeto/Estruturas/estruturas.cpp",
                "${workspaceFolder}/Projeto/Mapa/mapa.cpp",
                "${workspaceFolder}/Projeto/Personagem/personagem.cpp",
                "${workspaceFolder}/Projeto/Game/game.cpp",
                "${workspaceFolder}/Projeto/Menu/menu.cpp",
                "-o",
                "${workspaceFolder}/Projeto/programa.exe",
                "-I${workspaceFolder}/Projeto/raylib/include",
                "-L${workspaceFolder}/Projeto/raylib/lib",
                "-lraylib",
                "-lopengl32",
                "-lgdi32",
                "-lwinmm"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$gcc"],
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/C"]
                }
            }
        }
    ]
}
