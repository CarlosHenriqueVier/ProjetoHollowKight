{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Raylib",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Projeto/programa.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/Projeto",
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "preLaunchTask": "Compilar e Rodar Raylib",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}